# Shared environment file for all searcher-stack services.
# Copy this to .env (or .env.dev for local testing) and fill in your keys.
# This file is uploaded to both searcher and browser_worker during deployment.

# ── Scholarly search providers ────────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=
SERPAPI_API_KEY=
IEEE_XPLORE_API_KEY=
WEB_OF_SCIENCE_API_KEY=
ELSEVIER_API_KEY=

# ── searcher runtime tuning ───────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=20
PDF_MAX_MB=50
DOWNLOAD_DIR=/tmp/searcher_mcp_pdfs
MCP_USER_AGENT="searcher-mcp/1.0 (+https://localhost)"

# ── browser_worker runtime tuning ────────────────────────────────────────────
# Set automatically by the deploy script — override here if needed.
BROWSER_WORKER_CDP_URL=http://127.0.0.1:9222
BROWSER_WORKER_TIMEOUT_SECONDS=45
BROWSER_WORKER_MAX_DOWNLOAD_MB=100
BROWSER_WORKER_DOWNLOAD_DIR=/tmp/browser_worker_pdfs
BROWSER_WORKER_HEADLESS=true
BROWSER_WORKER_USER_AGENT="browser-worker/1.0 (+https://localhost)"
BROWSER_WORKER_SESSION_DIR=
